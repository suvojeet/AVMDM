target/
*.class
*.jar
*.war

# ── Frontend ──────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.*

# ── IDE ───────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/settings.json
.DS_Store

# ── Docker ────────────────────────────────────────────────────────────────
docker/data/
